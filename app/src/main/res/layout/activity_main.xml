<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/networkStatusBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#808080"
        android:gravity="center"
        android:padding="4dp"
        android:text="No Internet Connection"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:elevation="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@+id/magic_bottom_nav"
        app:layout_constraintTop_toBottomOf="@+id/networkStatusBanner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/magic_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FA0B0A15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipChildren="false">

        <!-- The Glowing Tubelight Indicator -->
        <FrameLayout
            android:id="@+id/floating_tubelight"
            android:layout_width="80dp"
            android:layout_height="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- The Gradient Ray -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:src="@drawable/bg_light_ray"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="2dp" />

            <!-- The Solid Tube -->
            <View
                android:layout_width="35dp"
                android:layout_height="3dp"
                android:background="@drawable/bg_tubelight"
                android:layout_gravity="top|center_horizontal" />

        </FrameLayout>

        <!-- Container for 5 click zones and icons -->
        <LinearLayout
            android:id="@+id/nav_items_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5">
            
            <!-- Item 1: Identify -->
            <LinearLayout
                android:id="@+id/nav_item_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/nav_icon_1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_camera"
                    android:tint="#FFFFFF"
                    app:tint="#FFFFFF"
                    android:alpha="0.4"/>
                <TextView
                    android:id="@+id/nav_text_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/identify"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:alpha="0.4" />
            </LinearLayout>

            <!-- Item 2: Volume -->
            <LinearLayout
                android:id="@+id/nav_item_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/nav_icon_2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:tint="#FFFFFF"
                    app:tint="#FFFFFF"
                    android:alpha="0.4"/>
                <TextView
                    android:id="@+id/nav_text_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/volume"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:alpha="0.4" />
            </LinearLayout>

            <!-- Item 3: History -->
            <LinearLayout
                android:id="@+id/nav_item_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/nav_icon_3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:tint="#FFFFFF"
                    app:tint="#FFFFFF"
                    android:alpha="0.4"/>
                <TextView
                    android:id="@+id/nav_text_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/history"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:alpha="0.4" />
            </LinearLayout>

            <!-- Item 4: Ocean Data -->
            <LinearLayout
                android:id="@+id/nav_item_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/nav_icon_4"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_ocean"
                    android:tint="#FFFFFF"
                    app:tint="#FFFFFF"
                    android:alpha="0.4"/>
                <TextView
                    android:id="@+id/nav_text_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/ocean_data"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:alpha="0.4" />
            </LinearLayout>

            <!-- Item 5: More -->
            <LinearLayout
                android:id="@+id/nav_item_5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/nav_icon_5"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:tint="#FFFFFF"
                    app:tint="#FFFFFF"
                    android:alpha="0.4"/>
                <TextView
                    android:id="@+id/nav_text_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/more"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:alpha="0.4" />
            </LinearLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>