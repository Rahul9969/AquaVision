<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_detection_card"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- Color indicator dot -->
    <View
        android:id="@+id/colorIndicator"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_ai_avatar" />

    <!-- Info column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/fishName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            tools:text="Rohu Fish (5)" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/confidenceBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:trackCornerRadius="4dp"
                app:trackThickness="8dp"
                app:indicatorColor="#0891B2"
                app:trackColor="#1E293B"
                android:progress="85" />

            <TextView
                android:id="@+id/confidenceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textSize="13sp"
                android:textColor="#CBD5E1"
                android:fontFamily="sans-serif-medium"
                tools:text="85%" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>